# Database — MySQL connection credentials
DB_HOST=localhost
DB_NAME=altheas_aquatic
DB_USER=root
DB_PASS=
DB_PORT=3306

# TiDB Cloud Serverless requires SSL
# Set to true when connecting to TiDB or any cloud MySQL that requires SSL
DB_SSL=false

# Application
# IMPORTANT: For local development with PayMongo webhooks, set this to your ngrok URL.
APP_URL=http://localhost:8000
APP_ENV=development

# Frontend URL (for CORS in production)
# Set to your Vercel deployment URL, e.g. https://altheas-aquatic.vercel.app
FRONTEND_URL=http://localhost:5173

# PayMongo Integration
# Get keys from https://dashboard.paymongo.com -> Developers -> API Keys
PAYMONGO_PUBLIC_KEY=pk_test_...
PAYMONGO_SECRET_KEY=sk_test_...

# PayMongo Webhook Secret
# Get from Dashboard -> Developers -> Webhooks after registering endpoint
PAYMONGO_WEBHOOK_SECRET=whsec_...

# Pusher Integration
# Get from https://dashboard.pusher.com/
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=ap1

# Cloudinary — Product Image Storage (Production)
# Get from https://console.cloudinary.com/settings/api-keys
# Leave empty for local file storage (development)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP — Email Notifications (Gmail App Password)
# Generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Althea's Aquatic
